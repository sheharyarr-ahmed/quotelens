{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "types": ["jest"],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  // scripts/ is Node tooling executed via tsx (needs node globals that the
  // RN typecheck deliberately excludes via "types": ["jest"]).
  "exclude": [
    "node_modules",
    "scripts"
  ]
}
