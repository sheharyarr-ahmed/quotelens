# --- backend (FastAPI) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service-role-key
SUPABASE_JWT_SECRET=jwt-secret
ANTHROPIC_API_KEY=sk-ant-...
# faster-whisper model: small (local/demo quality) | base (free-tier deploy, ~300MB)
WHISPER_MODEL=small
# Claude model ids, overridable per deploy (must be valid API ids — check /v1/models)
CLAUDE_VISION_MODEL=claude-sonnet-5
CLAUDE_TEXT_MODEL=claude-haiku-4-5-20251001

# --- demo scripts (scripts/seed_live_demo.py, seed_web_sample.py, mint_login_code.py) ---
# Which signed-up account the demo scripts read and write. No default: without it
# they require --email, so a clone can never target someone else's account.
QUOTELENS_DEMO_EMAIL=you@example.com
# Demo-only, default off. Seeds exactly one validation failure at retry_count==0 so
# the retry retraction is visible while capturing the walkthrough. Must be set on
# the process that runs the pipeline (see docs/SCREENSHOT_RUNBOOK.md).
# QUOTELENS_FORCE_RETRY=1

# --- tooling (Supabase CLI + Management API) ---
# Supabase CLI reads this and it takes precedence over a keychain login
# (run `set -a && source .env && set +a` before any supabase CLI call).
SUPABASE_ACCESS_TOKEN=sbp_...

# --- email OTP custom SMTP (Brevo) — read by scripts/configure_email_smtp.py ---
# Configures hosted Supabase to send the 6-digit sign-in code (SPEC v1.3.1/v1.4).
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=your-brevo-login
BREVO_SMTP_KEY=your-brevo-smtp-key
BREVO_SENDER_EMAIL=you@example.com
BREVO_SENDER_NAME=QuoteLens

# --- mobile (Expo) ---
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=anon-key
# The simulator reaches the backend on localhost (SPEC v1.5 dropped the LAN demo).
EXPO_PUBLIC_API_URL=http://localhost:8000
# Origin the app builds share links against (${EXPO_PUBLIC_WEB_URL}/q/<token>).
# Local: http://localhost:3000. Demo/prod: the deployed Vercel URL.
EXPO_PUBLIC_WEB_URL=http://localhost:3000

# --- web (Next.js) ---
# The public quote page reads server-only SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY
# (shared with the backend locally; set both server-only in Vercel, never NEXT_PUBLIC_).
# The NEXT_PUBLIC_ pair below is only a non-secret URL fallback; the anon key is unused by web.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=anon-key
